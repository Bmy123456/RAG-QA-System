# ========== 安全（必填） ==========
SECRET_KEY=change-me-in-production

# ========== LLM（必填） ==========
# 主 API Key，同时作为 LLM / Embedding / Reranker 的 fallback key
MIMO_API_KEY=sk-your-api-key-here
# 可选：DeepSeek API Key（当个别组件使用 deepseek provider 时需要）
DEEPSEEK_API_KEY=

# ========== LLM 配置 ==========
# 提供者: deepseek / openai / zhipu / qwen / mimo / ollama / vllm / tgi
LLM_PROVIDER=mimo
LLM_API_KEY=
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_MAX_MODEL_TOKENS=8192

# ========== Embedding 配置 ==========
# 提供者: openai / deepseek / zhipu / qwen / mimo / sentence-transformers / bge-large
EMBEDDING_PROVIDER=mimo
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.xiaomi.com/v1
EMBEDDING_MODEL=mimo-embed
EMBEDDING_DIMENSIONS=2048
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_CONCURRENCY=10
# 本地模型专用
EMBEDDING_DEVICE=cpu
EMBEDDING_MAX_WORKERS=4

# ========== Embedding 缓存 ==========
CACHE_ENABLED=true
CACHE_BACKEND=both

# ========== Reranker 配置 ==========
# 提供者: bge-reranker / cohere / llm-pointwise / llm-pairwise
# 或 LLM 别名: deepseek / openai / zhipu / qwen / mimo（自动映射到 llm-pointwise）
RERANKER_PROVIDER=mimo
RERANKER_TOP_K=5
# 跨编码器配置
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
# LLM 评分配置
RERANKER_API_KEY=
RERANKER_BASE_URL=https://api.xiaomi.com/v1
RERANKER_LLM_PROVIDER=mimo
RERANKER_MAX_CONCURRENCY=5

# ========== 检索配置 ==========
RETRIEVAL_INITIAL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5

# ========== 对话管理 ==========
CONV_MAX_TURNS=20
CONV_MAX_HISTORY_TOKENS=2000
CONV_REWRITE_ENABLED=true
CONV_REWRITE_DETECT=true
# 存储方式: memory（内存，重启丢失）/ database（SQLite 持久化）
CONV_STORAGE=database

# ========== 向量数据库 ==========
# 提供者: chroma / milvus / qdrant / weaviate
VECTOR_STORE_PROVIDER=chroma
# collection 模式: per-kb（每个知识库独立 collection）/ single（单 collection）
COLLECTION_MODE=per-kb
# 远程模式（仅 Chroma client/server / 其他向量库）
# VECTOR_STORE_HOST=localhost
# VECTOR_STORE_PORT=8000

# ========== 认证 ==========
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== 数据库 ==========
# 默认 SQLite，也支持 PostgreSQL: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=

# ========== 文档解析 ==========
MAX_UPLOAD_SIZE_MB=50

# ========== 知识库权限 ==========
ALLOW_PUBLIC_KB=true
KB_SHARING_ENABLED=false

# ========== 监控与评估 ==========
QA_LOGGING_ENABLED=true
