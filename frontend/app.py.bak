# 管理员反馈管理页面
# ---------------------------------------------------------------------------


def _admin_review(feedback_id: int, status: str):
    """管理员审核回调（在 expander 外层触发，避免 DOM 冲突）。"""
    api_put(f"/api/evaluation/feedback/{feedback_id}/status?status={status}")


def admin_feedback_page():
    """管理员反馈管理面板。"""
    st.title("📋 反馈管理")

    tab_dash, tab_manage, tab_export = st.tabs(["📊 仪表盘", "📝 反馈管理", "📥 数据导出"])

    # ---- 仪表盘 ----
    with tab_dash:
        stats = api_get("/api/evaluation/admin/stats")
        if stats:
            # 核心指标
            col1, col2, col3, col4 = st.columns(4)
            col1.metric("总反馈数", stats.get("total", 0))
            col2.metric("🟡 待处理", stats.get("pending_count", 0))
            col3.metric("👍 有用", stats.get("useful", 0))
            col4.metric("✏️ 纠正", stats.get("corrections", 0))

            sat = stats.get("satisfaction_rate", 0)
            st.progress(sat, text=f"满意度: {sat:.0%}")

            st.divider()

            # 7 天趋势
            trend = stats.get("trend", [])
            if trend:
                st.subheader("📈 近 7 天趋势")
                import pandas as pd
                df = pd.DataFrame(trend)
                df.columns = ["日期", "反馈数"]
                st.line_chart(df.set_index("日期"))

            # 类型分布
            dist = stats.get("distribution", {})
            if dist:
                st.subheader("📊 类型分布")
                col1, col2, col3 = st.columns(3)
                col1.metric("👍 有用", dist.get("useful", 0))
                col2.metric("👎 无用", dist.get("useless", 0))
                col3.metric("✏️ 纠正", dist.get("correction", 0))
        else:
            st.info("暂无统计数据")

    # ---- 反馈管理 ----
    with tab_manage:
        # 筛选栏
        col1, col2, col3, col4 = st.columns(4)
        with col1:
            fb_type = st.selectbox("类型", ["全部", "有用", "无用", "纠正"], key="admin_fb_type")
        with col2:
            fb_status = st.selectbox("状态", ["全部", "待处理", "已审阅", "已采纳", "忽略", "已关闭"], key="admin_fb_status")
        with col3:
            fb_kb = st.text_input("知识库 ID", key="admin_fb_kb", placeholder="留空=全部")
        with col4:
            fb_days = st.number_input("近 N 天", min_value=1, max_value=90, value=30, key="admin_fb_days")

        type_map = {"全部": None, "有用": "useful", "无用": "useless", "纠正": "correction"}
        status_map = {"全部": None, "待处理": "pending", "已审阅": "reviewed", "已采纳": "adopted", "忽略": "dismissed", "已关闭": "closed"}

        params = {"limit": 50}
        if type_map[fb_type]:
            params["feedback_type"] = type_map[fb_type]
        if status_map[fb_status]:
            params["status"] = status_map[fb_status]
        if fb_kb.strip():
            params["kb_id"] = int(fb_kb.strip())
        params["created_after"] = (datetime.utcnow() - timedelta(days=int(fb_days))).isoformat()

        result = api_get("/api/evaluation/feedback", params=params)
        items = result.get("items", []) if result else []
        total = result.get("total", 0) if result else 0

        st.caption(f"共 {total} 条反馈")

        type_icon = {"useful": "👍", "useless": "👎", "correction": "✏️"}.get
        status_badge = {
            "pending": "🟡 待处理", "reviewed": "🔵 已审阅",
            "adopted": "🟢 已采纳", "dismissed": "⚫ 已忽略", "closed": "⚫ 已关闭",
        }.get

        for fb in items:
            icon = type_icon(fb.get("feedback_type", ""), "❓")
            badge = status_badge(fb.get("status", "pending"), "🟡 待处理")
            question = fb.get("question", "")[:50] or "（无问题记录）"
            created = fb.get("created_at", "")[:19].replace("T", " ")

            with st.expander(f"{icon} {badge} | {question}… | {created}"):
                st.markdown(f"**用户 ID**: {fb.get('user_id', '-')} | **会话**: `{fb.get('session_id', '')[:12]}…`")
                if fb.get("question"):
                    st.markdown(f"**原始问题**: {fb['question']}")
                if fb.get("answer"):
                    st.markdown(f"**原始回答**: {fb['answer'][:500]}{'…' if len(fb.get('answer', '')) > 500 else ''}")
                if fb.get("reason"):
                    st.warning(f"**无用原因**: {fb['reason']}")
                if fb.get("correction"):
                    st.info(f"**纠正内容**: {fb['correction']}")
                if fb.get("sources_json"):
                    try:
                        sources = json.loads(fb["sources_json"])
                        if sources:
                            st.markdown("**引用来源**:")
                            for s in sources[:5]:
                                st.caption(f"  - {s.get('filename', '?')} (chunk {s.get('chunk_id', '?')})")
                    except (json.JSONDecodeError, TypeError):
                        pass
                if fb.get("admin_reply"):
                    st.success(f"**审核备注**: {fb['admin_reply']}")

                # 快速操作
                st.divider()
                col1, col2, col3, col4 = st.columns([1.5, 1.5, 1.5, 3])
                with col1:
                    st.button("🔵 已审核", key=f"review_{fb['id']}",
                              on_click=_admin_review, args=(fb["id"], "reviewed"))
                with col2:
                    st.button("🟢 已采纳", key=f"adopt_{fb['id']}",
                              on_click=_admin_review, args=(fb["id"], "adopted"))
                with col3:
                    st.button("⚫ 忽略", key=f"dismiss_{fb['id']}",
                              on_click=_admin_review, args=(fb["id"], "dismissed"))
                with col4:
                    reply = st.text_input("审核备注", key=f"reply_{fb['id']}", placeholder="填写备注后点击左侧按钮…")

    # ---- 数据导出 ----
    with tab_export:
        st.subheader("📥 导出反馈数据")
        col1, col2 = st.columns(2)
        with col1:
            export_type = st.selectbox("反馈类型", ["全部", "有用", "无用", "纠正"], key="export_type")
        with col2:
            export_status = st.selectbox("处理状态", ["全部", "待处理", "已审阅", "已采纳", "忽略"], key="export_status")

        export_params = {}
        type_map2 = {"全部": None, "有用": "useful", "无用": "useless", "纠正": "correction"}
        status_map2 = {"全部": None, "待处理": "pending", "已审阅": "reviewed", "已采纳": "adopted", "忽略": "dismissed"}
        if type_map2[export_type]:
            export_params["feedback_type"] = type_map2[export_type]
        if status_map2[export_status]:
            export_params["status"] = status_map2[export_status]

        if st.button("📥 导出 CSV", key="export_csv"):
            import io
            params_str = "&".join(f"{k}={v}" for k, v in export_params.items())
            url = f"/api/evaluation/admin/export?format=csv&{params_str}"
            data = api_get(url)
            if data:
                st.download_button(
                    "点击下载 CSV",
                    data=str(data),
                    file_name="feedback_export.csv",
                    mime="text/csv",
                )

        if st.button("📥 导出 JSON", key="export_json"):
            params_str = "&".join(f"{k}={v}" for k, v in export_params.items())
            url = f"/api/evaluation/admin/export?format=json&{params_str}"
            data = api_get(url)
            if data:
                st.download_button(
                    "点击下载 JSON",
                    data=json.dumps(data, ensure_ascii=False, indent=2),
                    file_name="feedback_export.json",
                    mime="application/json",
                )


# ---------------------------------------------------------------------------
# 评估页面
# ---------------------------------------------------------------------------


def evaluation_page():
    """评估与反馈查看页面。"""
    st.title("📊 评估与反馈")

    tab1, tab2, tab3 = st.tabs(["📈 综合统计", "💬 反馈记录", "📋 查询日志"])

    # ---- 综合统计 ----
    with tab1:
        stats = api_get("/api/evaluation/stats")
        if stats:
            fb = stats.get("feedback", {})
            ql = stats.get("query_log", {})

            st.subheader("📊 反馈统计")
            col1, col2, col3, col4 = st.columns(4)
            col1.metric("总反馈数", fb.get("total", 0))
            col2.metric("👍 有用", fb.get("useful", 0))
            col3.metric("👎 无用", fb.get("useless", 0))
            col4.metric("✏️ 纠正", fb.get("corrections", 0))

            # 满意度进度条
            sat = fb.get("satisfaction_rate", 0)
            st.progress(sat, text=f"满意度: {sat:.0%}")

            st.divider()
            st.subheader("📋 查询日志统计")
            col1, col2, col3, col4 = st.columns(4)
            col1.metric("总查询数", ql.get("total", 0))
            col2.metric("平均延迟", f"{ql.get('avg_latency_ms', 0):.0f} ms")
            col3.metric("平均 Token", f"{ql.get('avg_tokens', 0):.0f}")
            col4.metric("平均召回数", f"{ql.get('avg_retrieval_count', 0):.0f}")
        else:
            st.info("📭 暂无统计数据。使用问答功能并提交反馈后，统计数据将在此显示。")

    # ---- 反馈记录 ----
    with tab2:
        limit = st.slider("显示条数", 10, 200, 50, key="fb_limit")
        result = api_get("/api/evaluation/feedback", params={"limit": limit})
        feedbacks = result.get("items", []) if result else []
        if feedbacks:
            type_icon = {"useful": "👍", "useless": "👎", "correction": "✏️"}.get
            status_badge = {"pending": "🟡待处理", "reviewed": "🔵已审阅", "adopted": "🟢已采纳", "closed": "⚫已关闭"}.get
            for fb in feedbacks:
                icon = type_icon(fb.get("feedback_type", ""), "❓")
                badge = status_badge(fb.get("status", "pending"), "🟡待处理")
                with st.expander(f"{icon} {fb.get('feedback_type', '')} | {badge}"):
                    st.write(f"**用户 ID**: {fb.get('user_id', '-')}")
                    if fb.get("question"):
                        st.write(f"**问题**: {fb['question'][:200]}")
                    if fb.get("reason"):
                        st.write(f"**原因**: {fb['reason']}")
                    if fb.get("correction"):
                        st.write(f"**纠正**: {fb['correction']}")
                    if fb.get("admin_reply"):
                        st.info(f"**管理员回复**: {fb['admin_reply']}")
                    st.caption(fb.get("created_at", ""))
        else:
            st.info("暂无反馈记录")

    # ---- 查询日志 ----
    with tab3:
        limit = st.slider("显示条数", 10, 200, 50, key="log_limit")
        logs = api_get("/api/evaluation/logs", params={"limit": limit})
        if logs:
            for log in logs:
                latency = log.get("latency_ms", 0)
                color = "🟢" if latency < 2000 else ("🟡" if latency < 5000 else "🔴")
                with st.expander(f"{color} {log.get('question', '')[:50]}…"):
                    st.write(f"**问题**: {log.get('question', '')}")
                    if log.get("rewritten_query"):
                        st.write(f"**改写后**: {log['rewritten_query']}")
                    st.write(f"**回答**: {log.get('answer', '')[:200]}…")
                    col1, col2, col3 = st.columns(3)
                    col1.caption(f"延迟: {latency} ms")
                    col2.caption(f"Token: {log.get('token_total', 0)}")
                    col3.caption(f"召回: {log.get('retrieval_count', 0)} / 重排: {log.get('reranked_count', 0)}")
                    st.caption(f"模型: {log.get('model', '-')} | 策略: {log.get('retrieval_strategy', '-')}")
                    st.caption(log.get("created_at", ""))
        else:
            st.info("暂无查询日志")


# ---------------------------------------------------------------------------
# 向量库监控页面（管理员）
# ---------------------------------------------------------------------------


def vector_monitor_page():
    """管理员向量库监控面板。"""
    st.title("🔍 向量库监控")

    # --- 概览 ---
    stats = api_get("/api/admin/vectors/stats")
    if not stats:
        st.error("获取向量库信息失败")
        return

    col1, col2 = st.columns(2)
    col1.metric("Collections", stats["total_collections"])
    col2.metric("总 Chunks", stats["total_chunks"])

    collections = stats.get("collections", [])
    if not collections:
        st.info("向量库中暂无数据")
        return

    st.markdown("---")

    # --- Collection 选择 ---
    options = [
        f"{c['collection']}  |  {c.get('kb_name') or '-'}  |  {c['chunk_count']} chunks"
        for c in collections
    ]
    kb_ids = [c["kb_id"] for c in collections]

    selected = st.selectbox("选择知识库 Collection", options, key="vec_coll_select")
    idx = options.index(selected)
    kb_id = kb_ids[idx]

    if kb_id is None:
        st.warning("该 Collection 无关联知识库")
        return

    # --- 搜索 & 筛选 ---
    col_search, col_filter = st.columns([2, 1])
    with col_search:
        query = st.text_input("🔎 关键词搜索", key="vec_search_q", placeholder="输入文本关键词…")
    with col_filter:
        filename_filter = st.text_input("文件名筛选", key="vec_file_filter", placeholder="可选")

    # --- 分页 ---
    page_size = 20
    if "vec_page" not in st.session_state:
        st.session_state["vec_page"] = 1

    page = st.session_state["vec_page"]

    if query:
        result = api_get(
            f"/api/admin/vectors/{kb_id}/search",
            params={"q": query, "filename": filename_filter or None, "page": page, "page_size": page_size},
        )
    else:
        result = api_get(
            f"/api/admin/vectors/{kb_id}/chunks",
            params={"page": page, "page_size": page_size, "filename": filename_filter or None},
        )

    if not result:
        st.error("查询失败")
        return

    total = result["total"]
    items = result.get("items", [])
    total_pages = max(1, (total + page_size - 1) // page_size)

    st.caption(f"共 {total} 条  |  第 {page}/{total_pages} 页")

    # --- 分页按钮 ---
    nav1, nav2, nav3, nav4 = st.columns(4)
    with nav1:
        if st.button("⏮ 首页", key="vec_first", disabled=(page <= 1), use_container_width=True):
            st.session_state["vec_page"] = 1
            st.rerun()
    with nav2:
        if st.button("◀ 上一页", key="vec_prev", disabled=(page <= 1), use_container_width=True):
            st.session_state["vec_page"] = page - 1
            st.rerun()
    with nav3:
        if st.button("下一页 ▶", key="vec_next", disabled=(page >= total_pages), use_container_width=True):
            st.session_state["vec_page"] = page + 1
            st.rerun()
    with nav4:
        if st.button("末页 ⏭", key="vec_last", disabled=(page >= total_pages), use_container_width=True):
            st.session_state["vec_page"] = total_pages
            st.rerun()

    st.markdown("---")

    # --- Chunk 列表 ---
    if not items:
        st.info("本页无数据")
        return

    for item in items:
        chunk_id = item["chunk_id"]
        preview = item["text_preview"]
        meta = item.get("metadata", {})
        fname = item.get("filename", meta.get("filename", "-"))
        level = item.get("chunk_level", meta.get("chunk_level", "-"))
        modality = item.get("modality", meta.get("modality", "text"))
        created = item.get("created_at", meta.get("created_at", "-"))

        icon = "📝" if modality == "text" else "🖼️"
        level_tag = f" [{level}]" if level else ""

        with st.expander(f"{icon} `{chunk_id}`{level_tag} — {fname}"):
            st.text_area(
                "文本内容", preview, height=120, disabled=True,
                key=f"vec_txt_{chunk_id}",
            )
            col_a, col_b, col_c = st.columns(3)
            col_a.caption(f"文件: {fname}")
            col_b.caption(f"层级: {level or '-'}")
            col_c.caption(f"创建: {created[:19] if created and len(created) > 19 else created}")

            # 查看完整详情
            if st.button("📋 查看完整详情", key=f"vec_detail_{chunk_id}"):
                detail = api_get(f"/api/admin/vectors/{kb_id}/chunks/{chunk_id}")
                if detail:
                    st.json(detail)


# ---------------------------------------------------------------------------
# 入口
# ---------------------------------------------------------------------------


def main():
    st.set_page_config(
        page_title="RAG 智能问答",
        page_icon="🤖",
        layout="wide",
        initial_sidebar_state="expanded",
    )

    # 未登录 → 显示登录/注册页面
    if not st.session_state.get("access_token"):
        auth_page()
        return

    # 已登录 → 主界面
    sidebar_user()

    current_page = st.session_state.get("current_page", "chat")
    if current_page == "evaluation":
        evaluation_page()
    elif current_page == "admin_feedback":
        admin_feedback_page()
    elif current_page == "my_feedback":
        my_feedback_page()
    elif current_page == "vector_monitor":
        vector_monitor_page()
    else:
        sidebar_knowledge_base()
        sidebar_documents()
        sidebar_sessions()
        main_chat()


if __name__ == "__main__":
    main()
